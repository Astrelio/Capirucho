  "schema_base_datos": {
    "motor": "Supabase (PostgreSQL)",
    "tablas": [
      {
        "nombre": "restaurants",
        "descripcion": "Multi-tenant SaaS",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "name", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "slug", "tipo": "TEXT", "constraint": "UNIQUE NOT NULL" },
          { "nombre": "description", "tipo": "TEXT" },
          { "nombre": "address", "tipo": "TEXT" },
          { "nombre": "phone", "tipo": "TEXT" },
          { "nombre": "logo_url", "tipo": "TEXT" },
          { "nombre": "cover_url", "tipo": "TEXT" },
          { "nombre": "layout_json", "tipo": "JSONB", "default": "{}" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "profiles",
        "descripcion": "Extiende auth.users de Supabase",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "user_id", "tipo": "UUID", "constraint": "REFERENCES auth.users(id) ON DELETE CASCADE UNIQUE" },
          { "nombre": "full_name", "tipo": "TEXT" },
          { "nombre": "avatar_url", "tipo": "TEXT" },
          { "nombre": "phone", "tipo": "TEXT" },
          { "nombre": "role", "tipo": "TEXT", "constraint": "CHECK (role IN ('customer','waiter','admin','super_admin'))", "default": "'customer'" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id)" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "zones",
        "descripcion": "Zonas del restaurante",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "name", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "color", "tipo": "TEXT", "default": "'#555555'" },
          { "nombre": "position_x", "tipo": "FLOAT", "default": "0" },
          { "nombre": "position_y", "tipo": "FLOAT", "default": "0" },
          { "nombre": "width", "tipo": "FLOAT", "default": "400" },
          { "nombre": "height", "tipo": "FLOAT", "default": "300" },
          { "nombre": "sort_order", "tipo": "INT", "default": "0" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "tables",
        "descripcion": "Mesas",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "zone_id", "tipo": "UUID", "constraint": "REFERENCES zones(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "label", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "seats", "tipo": "INT", "constraint": "NOT NULL", "default": "4" },
          { "nombre": "shape", "tipo": "TEXT", "constraint": "CHECK (shape IN ('square','rectangle','circle'))", "default": "'square'" },
          { "nombre": "position_x", "tipo": "FLOAT", "default": "0" },
          { "nombre": "position_y", "tipo": "FLOAT", "default": "0" },
          { "nombre": "width", "tipo": "FLOAT", "default": "80" },
          { "nombre": "height", "tipo": "FLOAT", "default": "80" },
          { "nombre": "status", "tipo": "TEXT", "constraint": "CHECK (status IN ('available','occupied','reserved','blocked'))", "default": "'available'" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "reservations",
        "descripcion": "Reservaciones",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "table_id", "tipo": "UUID", "constraint": "REFERENCES tables(id) ON DELETE SET NULL" },
          { "nombre": "user_id", "tipo": "UUID", "constraint": "REFERENCES auth.users(id)" },
          { "nombre": "guest_name", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "guest_email", "tipo": "TEXT" },
          { "nombre": "guest_phone", "tipo": "TEXT" },
          { "nombre": "date", "tipo": "DATE", "constraint": "NOT NULL" },
          { "nombre": "time_start", "tipo": "TIME", "constraint": "NOT NULL" },
          { "nombre": "time_end", "tipo": "TIME", "constraint": "NOT NULL" },
          { "nombre": "party_size", "tipo": "INT", "constraint": "NOT NULL", "default": "2" },
          { "nombre": "status", "tipo": "TEXT", "constraint": "CHECK (status IN ('pending','confirmed','seated','completed','cancelled','no_show'))", "default": "'pending'" },
          { "nombre": "notes", "tipo": "TEXT" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "waitlist",
        "descripcion": "Lista de espera",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "guest_name", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "guest_phone", "tipo": "TEXT" },
          { "nombre": "guest_email", "tipo": "TEXT" },
          { "nombre": "party_size", "tipo": "INT", "constraint": "NOT NULL", "default": "2" },
          { "nombre": "status", "tipo": "TEXT", "constraint": "CHECK (status IN ('waiting','notified','seated','expired'))", "default": "'waiting'" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "menu_categories",
        "descripcion": "Categorías de menú",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "name", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "sort_order", "tipo": "INT", "default": "0" }
        ]
      },
      {
        "nombre": "menu_items",
        "descripcion": "Items de menú",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "category_id", "tipo": "UUID", "constraint": "REFERENCES menu_categories(id) ON DELETE SET NULL" },
          { "nombre": "name", "tipo": "TEXT", "constraint": "NOT NULL" },
          { "nombre": "description", "tipo": "TEXT" },
          { "nombre": "price", "tipo": "DECIMAL(10,2)", "constraint": "NOT NULL" },
          { "nombre": "image_url", "tipo": "TEXT" },
          { "nombre": "ai_generated", "tipo": "BOOLEAN", "default": "false" },
          { "nombre": "available", "tipo": "BOOLEAN", "default": "true" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      },
      {
        "nombre": "reviews",
        "descripcion": "Reseñas",
        "columnas": [
          { "nombre": "id", "tipo": "UUID", "default": "gen_random_uuid()", "constraint": "PRIMARY KEY" },
          { "nombre": "restaurant_id", "tipo": "UUID", "constraint": "REFERENCES restaurants(id) ON DELETE CASCADE NOT NULL" },
          { "nombre": "user_id", "tipo": "UUID", "constraint": "REFERENCES auth.users(id)" },
          { "nombre": "guest_name", "tipo": "TEXT" },
          { "nombre": "rating", "tipo": "INT", "constraint": "CHECK (rating >= 1 AND rating <= 5) NOT NULL" },
          { "nombre": "comment", "tipo": "TEXT" },
          { "nombre": "sentiment", "tipo": "TEXT", "constraint": "CHECK (sentiment IN ('positive','negative','neutral'))" },
          { "nombre": "sentiment_summary", "tipo": "TEXT" },
          { "nombre": "created_at", "tipo": "TIMESTAMPTZ", "default": "now()" }
        ]
      }
    ],
    "indices": [
      "CREATE INDEX idx_reservations_date ON reservations(restaurant_id, date, time_start);",
      "CREATE INDEX idx_reservations_table ON reservations(table_id, date);",
      "CREATE INDEX idx_tables_zone ON tables(zone_id);",
      "CREATE INDEX idx_tables_restaurant ON tables(restaurant_id);"
    ],
    "rpc_atomic_reserve": {
      "nombre": "atomic_reserve",
      "descripcion": "Reserva atómica anti-colisión. Esto reemplaza lo que el spec llama 'abaco'. La lógica la hacemos nosotros con PostgreSQL FOR UPDATE.",
      "parametros": [
        "p_restaurant_id UUID",
        "p_table_id UUID",
        "p_user_id UUID",
        "p_guest_name TEXT",
        "p_guest_email TEXT",
        "p_guest_phone TEXT",
        "p_date DATE",
        "p_time_start TIME",
        "p_time_end TIME",
        "p_party_size INT",
        "p_notes TEXT DEFAULT NULL"
      ],
      "retorna": "UUID",
      "logica": "Bloquea la mesa con FOR UPDATE, verifica solapamiento de horarios con reservas activas (pending/confirmed/seated). Si hay conflicto, lanza excepción 'COLLISION: Mesa ya reservada en ese horario'. Si no, inserta la reserva con status 'confirmed' y retorna su id."
    },
    "realtime": [
      "ALTER PUBLICATION supabase_realtime ADD TABLE tables;",
      "ALTER PUBLICATION supabase_realtime ADD TABLE reservations;"
    ]
  },

  "arquitectura_sistema": {
    "descripcion": "Diagrama Mermaid graph TB",
    "frontend_netlify_cdn": ["Landing", "Mapa (React Flow)", "Menú", "Admin (Editor Layout)", "Dashboard", "Onboarding SaaS"],
    "backend_netlify_functions": ["reserve()", "menu()", "analytics()", "analyze-review()", "scrape-menu()", "generate-image()", "codex-assist()"],
    "supabase": ["PostgreSQL", "Realtime", "Auth", "Storage", "RPC atomic_reserve()"],
    "apis_externas": ["n8n", "fal", "Mistral", "Minsky AtlasIQ", "Firecrawl", "Exa", "OpenAI Codex"],
    "conexiones": [
      "Landing --> PostgreSQL",
      "Mapa --Suscripción--> Realtime",
      "Mapa --> reserve()",
      "Menú --> PostgreSQL",
      "Admin --> PostgreSQL",
      "Admin --> Storage",
      "Dashboard --> analytics()",
      "Onboarding --> scrape-menu()",
      "reserve() --> RPC atomic_reserve()",
      "reserve() --Webhook--> n8n",
      "menu() --> PostgreSQL",
      "generate-image() --> fal",
      "generate-image() --> Storage",
      "analytics() --> PostgreSQL",
      "analytics() --> Minsky AtlasIQ",
      "analyze-review() --> Mistral",
      "analyze-review() --> PostgreSQL",
      "scrape-menu() --> Firecrawl",
      "scrape-menu() --> Exa",
      "codex-assist() --> OpenAI Codex",
      "Auth --JWT--> reserve()"
    ]
  },


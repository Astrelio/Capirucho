        { "id": "0.7", "hora": "1:45", "tarea": "Config Supabase frontend", "archivos": ["frontend/src/config/supabase.ts"], "detalle": "Reescribir para Vite: import.meta.env.VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY" },

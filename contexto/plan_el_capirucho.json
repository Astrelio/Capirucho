      "horario": "Hora 0–2",
      "tareas": [
        { "id": "0.1", "hora": "0:00", "tarea": "Inicializar frontend", "archivos": ["frontend/package.json", "frontend/vite.config.ts", "frontend/tsconfig.json", "frontend/index.html"], "detalle": "npx create-vite@latest frontend/ --template react-ts. Instalar: react-router-dom, @supabase/supabase-js, @xyflow/react, recharts" },
        { "id": "0.2", "hora": "0:15", "tarea": "Configurar Netlify", "archivos": ["netlify.toml", "netlify/functions/_shared/supabase.ts"], "detalle": "Build command, functions dir, redirect SPA, config de Supabase server-side con SUPABASE_SERVICE_ROLE_KEY" },
        { "id": "0.3", "hora": "0:30", "tarea": "Crear proyecto Supabase", "archivos": ["supabase/schema.sql"], "detalle": "Crear proyecto en supabase.com. Ejecutar schema SQL completo. Habilitar Realtime. Obtener URL + keys" },
        { "id": "0.4", "hora": "0:45", "tarea": "Variables de entorno", "archivos": [".env", ".env.example", ".gitignore"], "detalle": "Todas las API keys. .gitignore con node_modules, .env, dist/" },
        { "id": "0.5", "hora": "1:00", "tarea": "Design System", "archivos": ["frontend/src/styles/globals.css", "frontend/src/styles/components.css"], "detalle": "Reset CSS. Variables: --bg: #FFFFFF, --text: #111111, --primary: #555555. Google Fonts: Playfair Display + Inter. Botones, inputs, cards, modales" },
